# Copy to .env and fill in. Never commit a real credential.
# Every variable below except ANTHROPIC_API_KEY is optional; leaving the
# commented ones unset runs the agent exactly as shipped.

# --- Required ---
ANTHROPIC_API_KEY=

# --- Model ---
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Arize AX tracing (agent/tracing.py, scripts/push_to_arize.py) ---
# The Arize span sink turns on only when BOTH of these are set. Left empty,
# tracing falls back to the local JSONL sink and no data leaves the machine.
ARIZE_SPACE_ID=
ARIZE_API_KEY=
# ARIZE_PROJECT_NAME=travel-agent
# TRACE_EXPORT_PATH=   # default: <repo root>/traces/spans.jsonl
# TRACING_DISABLED=

# --- Agent loop termination controls (agent/config.py) ---
# Bound the tool-calling loop. On breach the turn stops and the agent returns a
# fixed "could not complete reliably" reply with no itinerary content.
# MAX_AGENT_ITERATIONS=8
# AGENT_DEADLINE_SECONDS=60

# --- Experiment gates (agent/prompt.py, agent/tools.py, agent/loop.py) ---
# Defaults are the shipped behavior. scripts/run_experiment.py sets these from
# its flags; set them by hand only for a manual run.
# PROMPT_VARIANT=
# FLIGHT_TOOL_FIX=0
# PROMPT_CACHE=0

# --- Tool retries (agent/tools.py) ---
# TOOL_MAX_RETRIES=3
# TOOL_RETRY_BASE_SECONDS=0.1

# --- API session storage (agent/session_store.py) ---
# Unset keeps conversations in process memory. "sqlite" persists them.
# SESSION_STORE=
# SESSION_DB_PATH=     # default: <repo root>/sessions.db

# --- Run labelling (agent/tracing.py, scripts/capture_baseline.py) ---
# PROMPT_VERSION=v0-shipped
# AGENT_VERSION=baseline-0080b11

# --- Tooling (scripts/) ---
# PROPOSER_MODEL=claude-opus-4-8
# TRAVEL_AGENT_URL=http://localhost:8000
